# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/flexmore

# Auth
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# Initial admin (used by `npm run create-admin`)
[email protected]
ADMIN_PASSWORD=admin123456
